TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: use local Telegram Bot API server for large files (>20 MB).
# When enabled, set local server URLs below.
TELEGRAM_LOCAL_MODE=false
TELEGRAM_API_BASE_URL=
TELEGRAM_API_FILE_URL=

# Auto-start local Telegram Bot API server from bot.py (single-command startup).
TELEGRAM_AUTO_START_LOCAL_API=false
TELEGRAM_BOT_API_BIN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_LOCAL_API_HOST=127.0.0.1
TELEGRAM_LOCAL_API_PORT=8081
TELEGRAM_LOCAL_API_DATA_DIR=.telegram-bot-api-data
# Optional: host path to Docker bind mount of /var/lib/telegram-bot-api
# Used as fallback when local Bot API file endpoint returns Not Found.
# Example: C:\Users\Gena\Documents\Playground\tg-bot-api-data
TELEGRAM_LOCAL_DOCKER_DATA_DIR=
TELEGRAM_BOT_API_EXTRA_ARGS=

# Request timeout tuning (seconds). Helpful for local Bot API with big files.
TELEGRAM_CONNECT_TIMEOUT=20
TELEGRAM_READ_TIMEOUT=120
TELEGRAM_WRITE_TIMEOUT=120
TELEGRAM_MEDIA_WRITE_TIMEOUT=180
TELEGRAM_POOL_TIMEOUT=15
TELEGRAM_GET_UPDATES_READ_TIMEOUT=30

# For very large files in local mode, try direct pickup from local Bot API storage first.
TELEGRAM_LOCAL_DIRECT_PICKUP_MB=40
TELEGRAM_LOCAL_PICKUP_WAIT_SECONDS=30

# Post-processing of final transcript text (orthography/punctuation, filler removal,
# and speaker name replacement when speakers introduce themselves).
TEXT_POSTPROCESS_ENABLED=true
TEXT_POSTPROCESS_PROVIDER=lmstudio
TEXT_POSTPROCESS_MODEL=gemini
# Gemini (Google AI Studio free tier)
# One or multiple keys (comma/semicolon/newline separated).
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TIMEOUT_SEC=180
# whisper | oos20
GEMINI_FALLBACK_MODEL=whisper
# LM Studio base URL (bot auto-detects /v1 or /api/v1).
# Examples:
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/api/v1
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_MODEL=
# Optional: custom prompt profile for LM Studio post-processing.
# Default: lmstudio_prompts.json next to bot.py/text_postprocessor.py
LMSTUDIO_PROMPTS_FILE=
LMSTUDIO_TIMEOUT_SEC=600
LMSTUDIO_TEMPERATURE=0.0
LMSTUDIO_REQUEST_RETRIES=2
LMSTUDIO_RETRY_BACKOFF_SEC=2.0
TEXT_POSTPROCESS_MAX_CHARS_PER_CHUNK=12000
TEXT_SUMMARY_MAX_CHARS_PER_CHUNK=20000
TEXT_POSTPROCESS_MIN_RESPLIT_CHARS=1200
# Max size (MB) for debug text-file mode (.txt/.md/.log/.json etc).
TEXT_DEBUG_MAX_MB=50

# Whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=large-v3

# Optional: enable CTranslate2 TransformersConverter import.
# Keep disabled (default) for faster/stable startup on Windows.
CT2_ENABLE_TRANSFORMERS_CONVERTER=false

# cpu (recommended), auto, or cuda
WHISPER_DEVICE=cuda

# int8 (fast), float16 (GPU), float32 (slower)
WHISPER_COMPUTE_TYPE=float16

# Automatic splitting for large files
TARGET_CHUNK_MB=20
MAX_CHUNK_SECONDS=900
CHUNK_OVERLAP_SECONDS=2.0

# Telegram Bot API download limit (MB). Default is 20 for cloud Bot API.
TELEGRAM_DOWNLOAD_LIMIT_MB=20

# Decoding quality controls
WHISPER_BEAM_SIZE=8
WHISPER_BEST_OF=8
WHISPER_TEMPERATURE=0.0
WHISPER_VAD_FILTER=false
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false

# diarization backend: nemo | auto | heuristic
# Note: NeMo backend is usually available on Python 3.11/3.12 environments.
DIARIZATION_BACKEND=nemo

# 0 = auto detect, or set fixed number like 2
# You can override per chat in Telegram with /speakers auto|2|3|4
NEMO_NUM_SPEAKERS=0

# NeMo dataloader workers.
# On Windows, keep 0 to avoid multiprocessing pickling errors.
NEMO_NUM_WORKERS=0

# Optional: additional DLL folders to prepend to PATH for bot process.
# Use ';' separator on Windows.
# Example:
# CUDA_EXTRA_PATHS=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v12.9\bin;C:\Program Files\NVIDIA\CUDNN\v9.20\bin\12.9\x64
CUDA_EXTRA_PATHS=

# Optional: additional FFmpeg bin folders for NeMo/pydub.
# Example:
# FFMPEG_EXTRA_PATHS=C:\ffmpeg\bin;C:\Program Files\ffmpeg\bin
FFMPEG_EXTRA_PATHS=
